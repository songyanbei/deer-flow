# Single source of truth for local environment-based configuration.
# Keep all deployment/runtime env vars in this file.

# TAVILY API Key
TAVILY_API_KEY=your-tavily-api-key

# Jina API Key
JINA_API_KEY=your-jina-api-key

# CORS Origins (comma-separated) - e.g., http://localhost:3000,http://localhost:3001
# CORS_ORIGINS=http://localhost:3000

# Frontend direct backend URLs (optional)
# Leave these commented out to use the default nginx proxy in normal local dev.
# NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:8001
# NEXT_PUBLIC_LANGGRAPH_BASE_URL=http://localhost:2024

# Optional:
# FIRECRAWL_API_KEY=your-firecrawl-api-key
# VOLCENGINE_API_KEY=your-volcengine-api-key
# OPENAI_API_KEY=your-openai-api-key
# GEMINI_API_KEY=your-gemini-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# NOVITA_API_KEY=your-novita-api-key  # OpenAI-compatible, see https://novita.ai
#
# OIDC Authentication (Resource Server mode)
# Set OIDC_ENABLED=true to require JWT authentication on all API endpoints.
# OIDC_ENABLED=false
# OIDC_ISSUER=https://auth.example.com/realms/your-realm
# OIDC_JWKS_URI=                          # Auto-discovered from OIDC_ISSUER if empty
# OIDC_AUDIENCE=                          # Leave empty to skip aud validation (recommended until stable)
# OIDC_VERIFY_SSL=true                    # Set false for self-signed certs
# OIDC_ALGORITHMS=RS256                   # Comma-separated signing algorithms
# OIDC_TENANT_CLAIMS=organization,tenant_id,org_id  # Claim names to extract tenant from (fallback: "default")
# OIDC_JWKS_CACHE_TTL=3600               # JWKS cache TTL in seconds
# OIDC_EXEMPT_PATHS=                      # Additional paths to skip auth (comma-separated)

# Moss-hub SSO (Ticket-based SSO)
# Set SSO_ENABLED=true to accept moss-hub tickets at /api/sso/callback and mint
# the df_session cookie. Works side-by-side with OIDC_ENABLED; the auth
# middleware routes by JWT ``kid``.
# SSO_ENABLED=false
# MOSS_HUB_BASE_URL=https://moss-hub.example.com
# MOSS_HUB_APP_KEY=your-app-key
# MOSS_HUB_APP_SECRET=your-app-secret-32-bytes-minimum
# MOSS_HUB_VERIFY_SSL=true
# MOSS_HUB_TENANT_ID=moss-hub
# DEERFLOW_JWT_SECRET=change-me-at-least-32-bytes-please-please
# SSO_JWT_TTL=28800                      # df_session TTL in seconds (default 8h)
# SSO_COOKIE_NAME=df_session
# SSO_COOKIE_DOMAIN=                     # Empty → host-only cookie
# SSO_COOKIE_SECURE=true                 # Must stay true in production
# ENVIRONMENT=dev                        # production / staging / dev

# Workflow/domain-agent data directory
# DEER_FLOW_HOME=/absolute/path/to/deer-flow/backend/.deer-flow
#
# Workflow/domain-agent MCP entrypoints (only needed if using workflow mode agents)
# CONTACTS_MCP_ENTRY=/absolute/path/to/mcp-servers/contacts/src/index.js
# MEETING_ASSISTANT_MCP_ENTRY=/absolute/path/to/mcp-servers/meeting-assistant/src/index.js
# TIME_SERVER_MCP_ENTRY=/absolute/path/to/mcp-servers/time-server/src/index.js
